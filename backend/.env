JWT_SECRET=school_mgmt_jwt_secret_key_2024_super_secure
JWT_REFRESH_SECRET=school_mgmt_refresh_secret_key_2024_super_secure
JWT_EXPIRE=1d
JWT_REFRESH_EXPIRE=7d
CLIENT_URL=http://localhost:5173
NODE_ENV=development
